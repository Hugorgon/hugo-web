# Sanity credentials sdílené se Studiem v `/studio/.env.local`.
#
# Zkopíruj tento soubor na `.env.local` v rootu a doplň stejné hodnoty,
# které máš ve `studio/.env.local`. Bez `SANITY_STUDIO_PROJECT_ID` frontend
# automaticky padá na local fallback v `src/data/` — visual zůstává stejný.
#
# Vite je vidí přes `envPrefix: ['VITE_', 'SANITY_STUDIO_']` ve `vite.config.ts`.

SANITY_STUDIO_PROJECT_ID=
SANITY_STUDIO_DATASET=production
